function UpdateTopTabs(tabName)
    for name, data in pairs(TopTabs) do
        local isActive = (name == tabName)
        Tween(data.Tab, 0.2, {BackgroundColor3 = isActive and Theme.TabActive or Color3.new(1,1,1), BackgroundTransparency = isActive and 0 or 1}):Play()
        data.Label.TextColor3 = isActive and Theme.Text or Theme.TextMuted
        data.Label.Font = isActive and Enum.Font.GothamBold or Enum.Font.GothamMedium
    end
end

