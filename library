local function CreateSlider(parent, text, position, min, max, default)
    local Container = Create("Frame", {
        Name = "Slider_"..text:gsub(" ", ""), Size = UDim2.new(1, -24, 0, 42),
        Position = position, BackgroundTransparency = 1, Parent = parent
    })
    Create("TextLabel", {
        Name = "Label", Size = UDim2.new(0.5, 0, 0, 16), Position = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1, Text = text, TextColor3 = Theme.Text, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left, Font = Enum.Font.GothamMedium, Parent = Container
    })
    local ValueLabel = Create("TextLabel", {
        Name = "Value", Size = UDim2.new(0, 40, 0, 16), Position = UDim2.new(1, -14, 0, 0),
        AnchorPoint = Vector2.new(1, 0), BackgroundTransparency = 1,
        Text = tostring(default), TextColor3 = Theme.Text, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Right, Font = Enum.Font.GothamBold, Parent = Container
    })
    local Track = Create("TextButton", {
        Name = "Track", Size = UDim2.new(1, -28, 0, 6), Position = UDim2.new(0, 14, 1, -14),
        BackgroundColor3 = Theme.Checkbox, BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, Parent = Container
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 3), Parent = Track})
    local fillPercent = math.clamp((default - min) / (max - min), 0, 1)
    local Fill = Create("Frame", {
        Name = "Fill", Size = UDim2.new(fillPercent, 0, 1, 0),
        BackgroundColor3 = Theme.Accent, BorderSizePixel = 0, ZIndex = 2, Parent = Track
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 3), Parent = Fill})
    local Thumb = Create("Frame", {
        Name = "Thumb", Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(fillPercent, 0, 0.5, 0), AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Theme.Accent, BorderSizePixel = 0, ZIndex = 3, Parent = Track
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Thumb})
    local Sliding = false
    local function UpdateSlider(input)
        local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
        Thumb.Position = UDim2.new(pos, 0, 0.5, 0)
        Fill.Size = UDim2.new(pos, 0, 1, 0)
        local Value = math.floor(min + (max - min) * pos)
        ValueLabel.Text = tostring(Value)
    end
    Track.MouseButton1Down:Connect(function()
        Sliding = true
        UpdateSlider(UserInputService:GetMouseLocation())
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then Sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if Sliding and input.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider(input) end
    end)
    return Container
end

local function CreateColorPicker(parent, text, position, defaultColor)
    local Container = Create("Frame", {
        Name = "Color_"..text:gsub(" ", ""), Size = UDim2.new(1, -24, 0, 30),
        Position = position, BackgroundTransparency = 1, Parent = parent
    })
    Create("TextLabel", {
        Name = "Label", Size = UDim2.new(1, -44, 1, 0), Position = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1, Text = text, TextColor3 = Theme.Text, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left, Font = Enum.Font.GothamMedium, Parent = Container
    })
    local ColorBox = Create("TextButton", {
        Name = "ColorBox", Size = UDim2.new(0, 26, 0, 20),
        Position = UDim2.new(1, -14, 0.5, 0), AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = defaultColor, BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, Parent = Container
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = ColorBox})
    
    local Popup = Create("Frame", {
        Name = "ColorPopup",
        Size = UDim2.new(0, 140, 0, 80),
        Position = UDim2.new(0, -14, 1, 4),
        AnchorPoint = Vector2.new(1, 0),
        BackgroundColor3 = Theme.Card,
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 50,
        Parent = Container
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 8), Parent = Popup})
    Create("UIStroke", {Color = Theme.CardBorder, Thickness = 1, Parent = Popup})
    
    local presets = {
        Color3.fromRGB(239, 68, 68),
        Color3.fromRGB(249, 115, 22),
        Color3.fromRGB(234, 179, 8),
        Color3.fromRGB(34, 197, 94),
        Color3.fromRGB(59, 130, 246),
        Color3.fromRGB(139, 92, 246),
        Color3.fromRGB(236, 72, 153),
        Color3.fromRGB(255, 255, 255)
    }
    
    for i, color in ipairs(presets) do
        local col = (i - 1) % 4
        local row = math.floor((i - 1) / 4)
        local Preset = Create("TextButton", {
            Name = "Preset"..i,
            Size = UDim2.new(0, 28, 0, 28),
            Position = UDim2.new(0, 6 + col * 32, 0, 6 + row * 32),
            BackgroundColor3 = color,
            BorderSizePixel = 0,
            Text = "",
            AutoButtonColor = false,
            ZIndex = 51,
            Parent = Popup
        })
        Create("UICorner", {CornerRadius = UDim.new(0, 6), Parent = Preset})
        
        Preset.MouseButton1Click:Connect(function()
            ColorBox.BackgroundColor3 = color
            Popup.Visible = false
        end)
        
        Preset.MouseEnter:Connect(function()
            Tween(Preset, 0.1, {Size = UDim2.new(0, 32, 0, 32)}):Play()
        end)
        Preset.MouseLeave:Connect(function()
            Tween(Preset, 0.1, {Size = UDim2.new(0, 28, 0, 28)}):Play()
        end)
    end
    
    ColorBox.MouseButton1Click:Connect(function()
        Popup.Visible = not Popup.Visible
    end)
    
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and Popup.Visible then
            local mousePos = input.Position
            local popupPos = Popup.AbsolutePosition
            local popupSize = Popup.AbsoluteSize
            local boxPos = ColorBox.AbsolutePosition
            local boxSize = ColorBox.AbsoluteSize
            
            local inPopup = mousePos.X >= popupPos.X and mousePos.X <= popupPos.X + popupSize.X and
                           mousePos.Y >= popupPos.Y and mousePos.Y <= popupPos.Y + popupSize.Y
            local inBox = mousePos.X >= boxPos.X and mousePos.X <= boxPos.X + boxSize.X and
                         mousePos.Y >= boxPos.Y and mousePos.Y <= boxPos.Y + boxSize.Y
            
            if not inPopup and not inBox then
                Popup.Visible = false
            end
        end
    end)
    
    return Container
end

