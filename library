local function CreateTabButton(name, position, size, active, pageName)
    local Tab = Create("TextButton", {
        Name = name, Size = size, Position = position,
        BackgroundColor3 = active and Theme.TabActive or Color3.new(1,1,1),
        BackgroundTransparency = active and 0 or 1, Text = "", AutoButtonColor = false, Parent = TabsRow
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = Tab})
    local Label = Create("TextLabel", {
        Name = "Label", Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1,
        Text = name, TextColor3 = active and Theme.Text or Theme.TextMuted, TextSize = 13,
        Font = active and Enum.Font.GothamBold or Enum.Font.GothamMedium, Parent = Tab
    })
    TopTabs[name] = {Tab = Tab, Label = Label, Page = pageName}
    Tab.MouseButton1Click:Connect(function()
        for _, data in pairs(TopTabs) do
            Tween(data.Tab, 0.2, {BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 1}):Play()
            data.Label.TextColor3 = Theme.TextMuted
            data.Label.Font = Enum.Font.GothamMedium
        end
        Tween(Tab, 0.2, {BackgroundColor3 = Theme.TabActive, BackgroundTransparency = 0}):Play()
        Label.TextColor3 = Theme.Text
        Label.Font = Enum.Font.GothamBold
        if pageName and TabPages[pageName] then
            for _, page in pairs(TabPages) do page.Visible = false end
            TabPages[pageName].Visible = true
        end
        CurrentTabName = name
    end)
    Tab.MouseEnter:Connect(function()
        if Tab.BackgroundTransparency == 1 then Tween(Tab, 0.15, {BackgroundColor3 = Theme.Card, BackgroundTransparency = 0.5}):Play() end
    end)
    Tab.MouseLeave:Connect(function()
        if Tab.BackgroundTransparency > 0 then Tween(Tab, 0.15, {BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 1}):Play() end
    end)
end

