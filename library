local function CreateMenuItem(name, order, active, pageName, tabName)
    local Item = Create("TextButton", {
        Name = name, Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = active and Theme.Card or Color3.new(1, 1, 1),
        BackgroundTransparency = active and 0 or 1,
        Text = "", LayoutOrder = order, AutoButtonColor = false, Parent = MenuContainer
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 10), Parent = Item})
    
    local Indicator = Create("Frame", {
        Name = "Indicator", Size = UDim2.new(0, 3, 0, 16),
        Position = UDim2.new(0, 0, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = Theme.Accent, BorderSizePixel = 0, Visible = active, Parent = Item
    })
    Create("UICorner", {CornerRadius = UDim.new(0, 2), Parent = Indicator})
    
    local Label = Create("TextLabel", {
        Name = "Label", Size = UDim2.new(1, -20, 1, 0), Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1, Text = name,
        TextColor3 = active and Theme.Text or Theme.TextMuted, TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left, Font = Enum.Font.GothamMedium, Parent = Item
    })
    
    Item.MouseButton1Click:Connect(function()
        for _, child in pairs(MenuContainer:GetChildren()) do
            if child:IsA("TextButton") then
                Tween(child, 0.2, {BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 1}):Play()
                if child:FindFirstChild("Label") then child.Label.TextColor3 = Theme.TextMuted end
                if child:FindFirstChild("Indicator") then child.Indicator.Visible = false end
            end
        end
        Tween(Item, 0.2, {BackgroundColor3 = Theme.Card, BackgroundTransparency = 0}):Play()
        Label.TextColor3 = Theme.Text
        Indicator.Visible = true
        if pageName and TabPages[pageName] then
            for _, page in pairs(TabPages) do page.Visible = false end
            TabPages[pageName].Visible = true
        end
        if tabName then CurrentTabName = tabName; UpdateTopTabs(tabName) end
    end)
    Item.MouseEnter:Connect(function()
        if Item.BackgroundTransparency == 1 then Tween(Item, 0.15, {BackgroundColor3 = Theme.Card, BackgroundTransparency = 0.5}):Play() end
    end)
    Item.MouseLeave:Connect(function()
        if Item.BackgroundTransparency > 0 then Tween(Item, 0.15, {BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 1}):Play() end
    end)
end

